from collections import deque, Counter

# Setup variables
CONTROL_NUM = 5
LOCAL_HAZARD = "TYPHOON"

# Initialize deque with a strict memory limit
data_buffer = deque(maxlen=5)

# Base burst sequence
burst = [
    (CONTROL_NUM, "WEATHER"),       # 5
    (CONTROL_NUM + 1, "TRAFFIC"),   # 6
    (CONTROL_NUM + 2, "WEATHER"),   # 7
    (CONTROL_NUM + 3, "WEATHER"),   # 8
    (CONTROL_NUM + 4, LOCAL_HAZARD),# 9
    (CONTROL_NUM + 5, "WEATHER"),   # 10
    (CONTROL_NUM + 6, "TRAFFIC")    # 11
]

# Data Expansion: Adding 7 (CONTROL_NUM + 2) custom alerts starting at TS 12
for i in range(7):
    burst.append((12 + i, "FIRE" if i % 2 == 0 else "TRAFFIC"))

# Algorithm: Sliding Window with Spam Rule
results = []
for ts, cat in burst:
    # Extract current categories in deque
    current_cats = [item[1] for item in data_buffer]
    counts = Counter(current_cats)
    
    # Spam Rule: Reject if category exists >= 2 times
    if counts[cat] < 2:
        data_buffer.append((ts, cat))
        results.append((ts, cat, "Y"))
    else:
        results.append((ts, cat, "N"))

# Final Analysis
final_sum = sum(alert[0] for alert in data_buffer)
final_output = list(data_buffer)

# Verification for specific assessment questions
weather_ts_8 = next(r[2] for r in results if r[0] == 8)
hazard_append = next(r[2] for r in results if r[1] == LOCAL_HAZARD)

print(f"Total Burst Size: {len(burst)}")
print(f"Weather @ TS 8 Appended: {weather_ts_8}")
print(f"Hazard Appended: {hazard_append}")
print(f"Final Sum: {final_sum}")
print(f"Final Deque: {final_output}")

