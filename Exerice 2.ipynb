# Setup variables
CONTROL_NUM = 5
FAVORITE_ARTIST = "LOLA AMOUR"

# Initialize Sets
festival = {"Ben&Ben", "SB19", "Bini", "Eraserheads", FAVORITE_ARTIST, "Zild", f"Indie Artist {CONTROL_NUM}"}
user_a = {"Ben&Ben", "Bini", "Maki", "Dionela", FAVORITE_ARTIST}
user_b = {"SB19", "Eraserheads", "Zild", f"Indie Artist {CONTROL_NUM}", "Parokya ni Edgar"}

# Data Expansion: Add exactly 5 new artists
new_artists = {"Munimuni", "Autotelic", "Over October", "Any Name's Okay", "The Itchyworms"}
festival.update(new_artists)

# Jaccard Similarity Algorithm
def get_jaccard(user_set, festival_set):
    intersection = user_set.intersection(festival_set)
    union = user_set.union(festival_set)
    similarity = (len(intersection) / len(union)) * 100
    return similarity, len(intersection), len(union)

# Calculate results
sim_a, inter_a, union_a = get_jaccard(user_a, festival)
sim_b, inter_b, union_b = get_jaccard(user_b, festival)
dealbreakers_a = user_a.difference(festival)

# Output for Assessment Table
print(f"Total Artists in Festival: {len(festival)}")
print(f"User A Intersection: {inter_a}")
print(f"User A Union: {union_a}")
print(f"User A Jaccard: {sim_a:.2f}%")
print(f"User B Jaccard: {sim_b:.2f}%")
print(f"User A Dealbreakers: {dealbreakers_a}")

